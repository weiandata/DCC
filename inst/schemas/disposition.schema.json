{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/weiandata/DCC/schemas/disposition.schema.json",
  "title": "DCC terminal disposition",
  "description": "One terminal disposition row produced by dcc_execute().",
  "type": "object",
  "required": ["finding_id", "action", "status", "message"],
  "properties": {
    "finding_id": { "type": "string" },
    "action": {
      "type": ["string", "null"],
      "enum": ["exclude", "set_na", "flag", "recode", null]
    },
    "status": {
      "type": "string",
      "enum": [
        "changed", "excluded", "flagged", "skipped", "failed", "unhandled"
      ]
    },
    "message": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
