{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/weiandata/DCC/schemas/audit-log.schema.json",
  "title": "DCC audit-log row",
  "description": "One cell-level change row of a dcc_execute() audit log.",
  "type": "object",
  "required": [
    "finding_id",
    "record_id",
    "variable",
    "old_value",
    "new_value",
    "action",
    "check_id",
    "method",
    "timestamp",
    "dcc_version",
    "ruleset_hash",
    "keyfile_hash"
  ],
  "properties": {
    "finding_id": { "type": "string" },
    "record_id": { "type": ["string", "null"] },
    "variable": { "type": ["string", "null"] },
    "old_value": { "type": ["string", "null"] },
    "new_value": { "type": ["string", "null"] },
    "action": {
      "type": "string",
      "enum": ["exclude", "set_na", "flag", "recode"]
    },
    "check_id": { "type": "string" },
    "method": { "type": "string" },
    "timestamp": { "type": "string" },
    "dcc_version": { "type": "string" },
    "ruleset_hash": { "type": ["string", "null"] },
    "keyfile_hash": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
