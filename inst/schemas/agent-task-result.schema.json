{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weiandata.com/dcc/schemas/agent-task-result-1.0.json",
  "title": "DCC agent acceptance task result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version", "task_id", "status", "attempts", "calls",
    "stable_codes", "artifacts", "result", "validated", "previewed"
  ],
  "properties": {
    "contract_version": {"const": "1.0"},
    "task_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["success", "corrected", "refused", "failed"]},
    "attempts": {"type": "integer", "minimum": 1, "maximum": 2},
    "calls": {
      "type": "array", "maxItems": 20,
      "items": {"type": "string", "minLength": 1}
    },
    "stable_codes": {
      "type": "array", "maxItems": 50,
      "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"}
    },
    "artifacts": {
      "type": "array", "maxItems": 50,
      "items": {"type": "string", "minLength": 1}
    },
    "result": {
      "type": "object", "maxProperties": 20,
      "additionalProperties": true
    },
    "validated": {"type": "boolean"},
    "previewed": {"type": "boolean"}
  }
}

