{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://weiandata.com/dcc/schemas/summary-1.0.json",
  "title": "DCC machine summary",
  "type": "object",
  "required": ["contract_version", "run_id", "status", "counts", "hashes", "top_findings", "artifacts", "next_actions"],
  "properties": {
    "contract_version": {"type": "string", "const": "1.0"},
    "run_id": {"type": "string"},
    "status": {"type": "string", "enum": ["success", "needs_review", "failed"]},
    "counts": {
      "type": "object",
      "required": ["input_rows", "output_rows", "findings_total", "changes_total", "excluded_total", "handled_total", "unhandled_total"],
      "properties": {
        "input_rows": {"type": "integer", "minimum": 0},
        "output_rows": {"type": "integer", "minimum": 0},
        "findings_total": {"type": "integer", "minimum": 0},
        "changes_total": {"type": "integer", "minimum": 0},
        "excluded_total": {"type": "integer", "minimum": 0},
        "handled_total": {"type": "integer", "minimum": 0},
        "unhandled_total": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "hashes": {
      "type": "object",
      "additionalProperties": {"type": ["string", "null"]}
    },
    "top_findings": {"type": "array", "items": {"type": "object"}, "maxItems": 20},
    "artifacts": {"type": "array", "items": {"type": "string"}},
    "next_actions": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
