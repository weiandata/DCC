{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/weiandata/DCC/schemas/rules.schema.json",
  "title": "DCC rule set",
  "description": "A dcc_rules() YAML rule file, parsed to JSON.",
  "type": "object",
  "required": ["checks"],
  "properties": {
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "range",
              "set",
              "expr",
              "skip_logic",
              "missing_items",
              "straightlining",
              "response_time",
              "trap_items",
              "score_anomaly"
            ]
          },
          "severity": { "type": "string", "enum": ["info", "warn", "fail"] },
          "dimension": { "type": "string" },
          "variable": { "type": "string" },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "values": { "type": "array" },
          "expr": { "type": "string" },
          "when": {
            "type": "object",
            "properties": {
              "variable": { "type": "string" },
              "equals": {}
            }
          },
          "then_not_required": {
            "type": "array",
            "items": { "type": "string" }
          },
          "items": { "type": "array", "items": { "type": "string" } },
          "max_prop": { "type": "number" },
          "max_run": { "type": "integer" },
          "time_var": { "type": "string" },
          "min_seconds": { "type": "number" },
          "min_median_ratio": { "type": ["number", "null"] },
          "traps": { "type": "object" },
          "max_failed": { "type": "integer" },
          "score_var": { "type": "string" },
          "group_vars": { "type": "array" },
          "method": { "type": "string" },
          "k": { "type": "number" },
          "group_mean_z": { "type": "number" }
        }
      }
    }
  }
}
