{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://weiandata.com/dcc/schemas/reconciliation-1.0.json",
  "title": "DCC machine reconciliation record",
  "type": "object",
  "required": ["contract_version", "run_id", "finding_id", "record_id", "variable", "check_id", "evidence", "severity", "dimension", "code", "detector_id", "action", "status", "message", "handled"],
  "properties": {
    "contract_version": {"type": "string", "const": "1.0"},
    "run_id": {"type": "string"},
    "finding_id": {"type": "string"},
    "record_id": {"type": ["string", "null"]},
    "variable": {"type": ["string", "null"]},
    "check_id": {"type": "string"},
    "evidence": {"type": ["string", "null"]},
    "severity": {"type": "string", "enum": ["info", "warn", "fail"]},
    "dimension": {"type": ["string", "null"]},
    "code": {"type": "string"},
    "detector_id": {"type": "string"},
    "action": {"type": ["string", "null"]},
    "status": {"type": "string", "enum": ["changed", "excluded", "flagged", "skipped", "failed", "unhandled"]},
    "message": {"type": ["string", "null"]},
    "handled": {"type": "boolean"}
  },
  "additionalProperties": false
}
