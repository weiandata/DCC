{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://weiandata.com/dcc/schemas/audit-record-1.0.json",
  "title": "DCC machine audit record",
  "type": "object",
  "required": ["contract_version", "run_id", "finding_id", "record_id", "variable", "old_value", "new_value", "action", "check_id", "method", "timestamp", "dcc_version", "ruleset_hash", "keyfile_hash"],
  "properties": {
    "contract_version": {"type": "string", "const": "1.0"},
    "run_id": {"type": "string"},
    "finding_id": {"type": "string"},
    "record_id": {"type": ["string", "null"]},
    "variable": {"type": ["string", "null"]},
    "old_value": {"type": ["string", "null"]},
    "new_value": {"type": ["string", "null"]},
    "action": {"type": "string", "enum": ["exclude", "set_na", "flag", "recode"]},
    "check_id": {"type": "string"},
    "method": {"type": "string"},
    "timestamp": {"type": "string", "pattern": "Z$"},
    "dcc_version": {"type": "string"},
    "ruleset_hash": {"type": ["string", "null"]},
    "keyfile_hash": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
