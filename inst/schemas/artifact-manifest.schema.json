{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://weiandata.com/dcc/schemas/artifact-manifest-1.0.json",
  "title": "DCC artifact manifest",
  "type": "object",
  "required": ["contract_version", "run_id", "status", "hash_algorithm", "artifacts", "schemas"],
  "properties": {
    "contract_version": {"type": "string", "const": "1.0"},
    "run_id": {"type": "string"},
    "status": {"type": "string", "enum": ["success", "partial_failure", "failed"]},
    "hash_algorithm": {"type": "string", "const": "SHA-256"},
    "artifacts": {"type": "array", "items": {
      "type": "object",
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {"type": "string"},
        "bytes": {"type": "number", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }},
    "schemas": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
