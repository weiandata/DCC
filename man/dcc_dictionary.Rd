\name{dcc_dictionary}
\alias{dcc_dictionary}
\title{Canonical variable dictionary}
\usage{
dcc_dictionary(x)
}
\arguments{
\item{x}{A \code{dcc_data} object.}
}
\value{
A copy of the canonical variable dictionary.
}
\description{
Returns the declared source name, canonical name, type, role, and any adapter
metadata retained for each imported variable.
}
